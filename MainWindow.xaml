<Window x:Class="MAPA_PROG.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MAPA_PROG"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Image Name="MapImage"
           Source="/img/czechia.png"
           Stretch="Uniform"
           SizeChanged="MapImage_SizeChanged"
           MouseDown="MapImage_MouseDown"/>

        <Canvas Name="OverlayCanvas"/>

        <Button Width="100" Height="20" Margin="242,162,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Panel.ZIndex="10">Praha</Button>

        <Button Width="100" Height="20" Margin="600,184,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Panel.ZIndex="10">Ostrava</Button>

        <Button Width="100" Height="20" Margin="476,280,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Panel.ZIndex="10">Brno</Button>
    </Grid>
</Window>
